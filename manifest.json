{
  "manifest_version": 3,
  "name": "SafeSearch AI",
  "version": "1.0",
  "description": "AI-powered assistant that detects and redacts sensitive information in search queries.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://google.com/*",
    "*://*.google.com/*",
    "*://bing.com/*",
    "*://*.bing.com/*",
    "*://duckduckgo.com/*",
    "*://*.duckduckgo.com/*",
    "*://chatgpt.com/*",
    "*://*.chatgpt.com/*",
    "*://claude.ai/*",
    "*://*.claude.ai/*",
    "*://gemini.google.com/*",
    "*://*.gemini.google.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://google.com/*",
        "*://*.google.com/*",
        "*://bing.com/*",
        "*://*.bing.com/*",
        "*://duckduckgo.com/*",
        "*://*.duckduckgo.com/*",
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://gemini.google.com/*",
        "*://*.gemini.google.com/*"
      ],
      "css": ["src/content/content.css"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "SafeSearch AI Settings"
  }
}
